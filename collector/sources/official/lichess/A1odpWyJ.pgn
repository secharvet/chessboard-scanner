[Event "13th Amber Rapid"]
[Site "Monte Carlo MNC"]
[Date "2004.03.23"]
[Round "4"]
[White "Peter Svidler"]
[Black "Francisco Vallejo Pons"]
[Result "0-1"]
[WhiteElo "2747"]
[BlackElo "2663"]
[Annotator "https://lichess.org/@/Mr_Penings"]
[Variant "Standard"]
