[White "Cambridge Springs"]
[Black "Popular 7.Nd2"]
[Result "*"]
[Annotator "Eric"]
[Variant "Standard"]
[ECO "D52"]
[Opening "Queen's Gambit Declined: Cambridge Springs Defense, Bogoljubow Variation"]
[StudyName "Singapore Openings MasterClass"]
[ChapterName "Cambridge Springs - Popular 7.Nd2"]
