1:40] } 26. Qf4 { [%clk 0:01:10] } 26... Rhb8 { [%clk 0:01:35] } 27. Ne4 { [%clk 0:01:10] } 27... Qa5 { [%clk 0:01:19] } 28. Nxf6+ { [%clk 0:00:56] } (28. Ng5+! Kg8 29. h7+ Kg7 30. Rxe7 Qb4 31. Rxf7+ Kh8 { This position is far from clear. Both sides have extremely dangerous attacks. It is up to who can maintain an offense/defense balance. }) 28... exf6 { [%clk 0:01:05] } 29. Re7 { [%clk 0:00:57] } 29... Be8 { [%clk 0:00:39] } 30. Ne6 { [%clk 0:00:34] } 30... Qf5 { [%clk 0:00:09] } 31. Qc7 { [%clk 0:00:10] } 31... R6b7 { [%clk 0:00:05] } 32. Nf8+ { [%clk 0:00:09] } 32... Kh8 { White's threats are put on hold. Next up for Black: Rxb2 and the game } { [%clk 0:00:05] } 33. Qxb7 { [%clk 0:00:07] } 33... Rxb7 { [%clk 0:00:05] } 34. Rxe8 { [%clk 0:00:06] } 34... Qxc2 { Fortunately, White doesn't have a mating net. The pawn on h6 is undefended } { [%clk 0:00:06] } 35. Rb1 { [%clk 0:00:06] } 35... c3 { [%clk 0:00:07] } 36. Nxg6+ { [%clk 0:00:06] } 36... Kh7 { [%clk 0:00:07] } 37. Nf8+ { [%clk 0:00:06] } 37... Kxh6 { 0-1 Black wins. } { [%clk 0:00:08] } 0-1


