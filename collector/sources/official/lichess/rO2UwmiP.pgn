} 27. Bxf6 { [%clk 0:10:03] } 27... gxf6 { [%clk 0:06:33] } 28. Nh5 { [%clk 0:08:00] } 28... Re6 { [%clk 0:06:36] } 29. Ra1 { From this point forward, my opponent converted the endgame with great technique, never giving me any opportunities for counterplay. } { [%clk 0:07:09] } 29... Rxa1 { [%clk 0:06:21] } 30. Rxa1 { [%clk 0:07:37] } 30... Kf8 { [%clk 0:06:15] } 31. Kf1 { [%clk 0:06:00] } 31... c3 { [%clk 0:04:15] } 32. Rc1 { [%clk 0:03:01] } 32... Ba6+ { [%clk 0:04:02] } 33. Kg1 { [%clk 0:03:30] } 33... Re4 { [%clk 0:02:41] } 34. Nxf6 { [%clk 0:03:02] } 34... Rc4 { [%clk 0:01:29] } 35. Nd7+ { [%clk 0:03:19] } 35... Ke8 { [%clk 0:01:41] } 36. Ne5 { [%clk 0:03:25] } 36... Rxb4 { [%clk 0:01:39] } 37. Rxc3 { [%clk 0:03:40] } 37... Bb5 { [%clk 0:01:40] } 38. Ra3 { [%clk 0:02:33] } 38... Ba4 { [%clk 0:00:50] } 39. Nd3 { [%clk 0:00:59] } 39... Rc4 { [%clk 0:01:02] } 40. Ne5 { [%clk 0:00:41] } 40... Rb4 { [%clk 0:00:40] } 41. g4 { [%clk 0:24:32] } 41... f6 { [%clk 0:28:06] } 42. Nf3 { [%clk 0:22:58] } 42... Kd7 { [%clk 0:25:08] } 43. Nd4 { [%clk 0:22:59] } 43... Rc4 { [%clk 0:21:36] } 44. Kg2 { [%clk 0:22:47] } 44... Kc7 { [%clk 0:21:11] } 45. Kg3 { [%clk 0:19:47] } 45... Kb7 { [%clk 0:19:22] } 46. h4 { [%clk 0:18:16] } 46... Bb5 { [%clk 0:17:08] } 47. Ne6 { [%clk 0:13:06] } 47... Re4 { [%clk 0:15:14] } 48. Nd4 { [%clk 0:13:02] } 48... Bc4 { [%clk 0:12:49] } 49. Nf5 { [%clk 0:10:33] } 49... Re5 { [%clk 0:12:09] } 50. Nd6+ { [%clk 0:10:07] } 50... Kb8 { [%clk 0:12:24] } 51. Ra4 { [%clk 0:06:43] } 51... Be2 { [%clk 0:09:57] } 52. Rb4+ { [%clk 0:06:34] } 52... Ka8 { [%clk 0:09:46] } 53. Rb6 { [%clk 0:06:25] } 53... Re7 { [%clk 0:08:29] } 54. Rxc6 { [%clk 0:06:26] } 54... Rg7 { [%clk 0:08:57] } 55. f3 { [%clk 0:06:33] } 55... h5 { [%clk 0:09:01] } 56. Nf5 { [%clk 0:05:20] } 56... Rg8 { [%clk 0:08:58] } 57. Nd4 { [%clk 0:04:24] } 57... Bd1 { [%clk 0:04:26] } 58. Ra6+ { [%clk 0:04:48] } 58... Kb7 { [%clk 0:04:53] } 59. Ra1 { A fitting ending, trapping the problem bishop. } { [%