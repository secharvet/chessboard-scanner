[Annotator "https://lichess.org/@/NoseKnowsAll"]
[FEN "r1bq1rk1/ppppbppp/2n2n2/1B6/3PP3/5N2/PP3PPP/RNBQ1RK1 w - - 1 8"]
[SetUp "1"]
